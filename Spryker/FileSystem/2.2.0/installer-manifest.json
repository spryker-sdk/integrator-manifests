{
    "configure-env": [
        {
            "target": "\\Spryker\\Shared\\FileSystem\\FileSystemConstants::FILESYSTEM_SERVICE",
            "value": {
                "backoffice-media": {
                    "sprykerAdapterClass": "\\Spryker\\Service\\FlysystemAws3v3FileSystem\\Plugin\\Flysystem\\Aws3v3FilesystemBuilderPlugin::class",
                    "key": "getenv('SPRYKER_S3_PUBLIC_ASSETS_KEY') ?: ''",
                    "bucket": "getenv('SPRYKER_S3_PUBLIC_ASSETS_BUCKET') ?: ''",
                    "secret": "getenv('SPRYKER_S3_PUBLIC_ASSETS_SECRET') ?: ''",
                    "root": "/backoffice-media",
                    "path": "/",
                    "version": "latest",
                    "region": "getenv('AWS_REGION')"
                }
            }
        },
        {
            "target": "\\Spryker\\Shared\\FileSystem\\FileSystemConstants::FILESYSTEM_SERVICE",
            "value": {
                "storefront-media": {
                    "sprykerAdapterClass": "\\Spryker\\Service\\FlysystemAws3v3FileSystem\\Plugin\\Flysystem\\Aws3v3FilesystemBuilderPlugin::class",
                    "key": "getenv('SPRYKER_S3_PUBLIC_ASSETS_KEY') ?: ''",
                    "bucket": "getenv('SPRYKER_S3_PUBLIC_ASSETS_BUCKET') ?: ''",
                    "secret": "getenv('SPRYKER_S3_PUBLIC_ASSETS_SECRET') ?: ''",
                    "root": "/storefront-media",
                    "path": "",
                    "version": "latest",
                    "region": "getenv('AWS_REGION')"
                }
            }
        },
        {
            "target": "\\Spryker\\Shared\\FileSystem\\FileSystemConstants::FILESYSTEM_SERVICE",
            "value": {
                "merchant-portal-media": {
                    "sprykerAdapterClass": "\\Spryker\\Service\\FlysystemAws3v3FileSystem\\Plugin\\Flysystem\\Aws3v3FilesystemBuilderPlugin::class",
                    "key": "getenv('SPRYKER_S3_PUBLIC_ASSETS_KEY') ?: ''",
                    "bucket": "getenv('SPRYKER_S3_PUBLIC_ASSETS_BUCKET') ?: ''",
                    "secret": "getenv('SPRYKER_S3_PUBLIC_ASSETS_SECRET') ?: ''",
                    "root": "/merchant-portal-media",
                    "path": "",
                    "version": "latest",
                    "region": "getenv('AWS_REGION')"
                }
            }
        }
    ]
}
